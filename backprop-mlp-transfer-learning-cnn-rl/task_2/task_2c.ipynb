import numpy as np

"""
Neural network with forward and backwards pass
"""


class NeuralNet:
    def __init__(self, seed: int = 42, layer_sizes: list[int] = [4, 5, 3, 3]):
        """Initializes neural network of the specified hyperparameters.
        For each layer l:
            weights[l] connecting layer l to l+1: shape (layer_sizes[l+1], layer_sizes[l])
            biases[l] connecting layer l to l+1: shape (layer_sizes[l+1], 1)

        Arguments:
            seed -- integer for reproducability
            layer_sizes -- List of neurons per layer, len = num_layers
        """
        self.weights = []  # len = num_layers - 1
        self.biases = []  # len = num_layers - 1
        self.layer_sizes = layer_sizes  # len = num_layers

        np.random.seed(seed)

        for l in range(1, len(layer_sizes)):
            # weights[l] shape: (current_layer_size, previous_layer_size)
            self.weights.append(np.random.randn(layer_sizes[l], layer_sizes[l - 1]))
            # biases[l] shape: (current_layer_size, 1)
            self.biases.append(np.random.randn(layer_sizes[l], 1))

        # print(f"Initialized nerual network with layer_sizes {layer_sizes}.")

    def tanh(self, z: np.ndarray) -> np.ndarray:
        """Hyperbolic tangent activation function.
        Maps real numbers to [-1,1] range.

        Arguments:
            z -- Input to activation function
        Returns:
            tanh(z) element-wise
        """
        return np.tanh(z)

    def tanh_prime(self, z: np.ndarray) -> np.ndarray:
        """Derivative of tanh activation function.
        Used during backpropagation to compute gradients.

        Arguments:
            z -- Input to activation function
        Returns:
            1 - tanh^2(z) element-wise
        """
        return 1.0 - np.square(np.tanh(z))

    def softmax(self, z: np.ndarray) -> np.ndarray:
        """Computes softmax on logits

        Arguments:
            z -- logits of dim self.layer_sizes[-1]

        Returns:
             Probability distribution where elements sum to 1
        """
        # subtract max for numerical stability
        exp_z = np.exp(z - np.max(z))  # of dim self.layer_sizes[-1]
        sum_exp = np.sum(exp_z)  # of dim 1
        return exp_z / sum_exp  # of dim self.layer_sizes[-1]

    def cross_entropy_loss(self, y_pred: np.ndarray, y_true: np.ndarray) -> float:
        """Computes CE on predicted probability distribution and true labels (one-hot-encoded)

        Arguments:
            y_pred -- Output of softmax, shape (output_size, 1)
            y_true -- One-hot encoded target, shape (output_size, 1)
        Returns:
            Cross entropy loss (scalar)
        """

        # Add small epsilon to avoid log(0)
        epsilon = 1e-15
        y_pred = np.clip(y_pred, epsilon, 1 - epsilon)

        return -np.sum(y_true * np.log(y_pred))

    def forward(self, x: np.ndarray) -> tuple[list, list]:
        """Compute activations for all layers given input x.

        Arguments:
            x -- Input data, shape: (input_size x 1)

        Returns:
            activations -- List of activations for each layer, of dim self.layer_sizes
            zs -- List of weighted inputs for each layer, of dim self.layer_sizes
        """
        activation = x  # (layer_size[0], 1)
        activations = [x]  # list to store activations of all layers
        zs = []  # list to store z vectors (weighted inputs) of all layers

        # For each layer
        for i in range(len(self.layer_sizes) - 1):
            # weights[l] shape: (current_layer_size, previous_layer_size)
            # biases[l] shape: (current_layer_size, 1)
            w, b = self.weights[i], self.biases[i]

            # z[l] shape: (current_layer_size, 1), input to next layer
            z = np.dot(w, activation) + b
            zs.append(z)
            # activation on z, tanh on all layers except last (softmax)
            # activation[l+1] shape: (current_layer_size, 1)
            activation = (
                self.tanh(z) if (i != len(self.layer_sizes) - 2) else self.softmax(z)
            )
            activations.append(activation)

        return activations, zs

    def backwards(
        self, activations: list[np.ndarray], zs: list[np.ndarray], y: np.ndarray
    ) -> tuple[list[np.ndarray], list[np.ndarray]]:
        """After forward pass, compute gradients for weights and biases using backprop.

        Arguments:
            activations -- output activations from forward pass of len L, shape (layer_size[l], 1)
            zs -- output zs (pre-act) from forward pass of len L, shape (layer_size[l], 1)
            y -- One-hot encoded labels, shape: (output_layer_size, 1)

        Returns:
            nabla_w -- List of weight gradients, each shape matches weights[l]: (layer_size[l+1], layer_size[l])
            nabla_b -- List of bias gradients, each shape matches biases[l]: (layer_size[l+1], 1)
        """

        # Initial delta for output layer
        # delta[L] shape: (layer_size[-1], 1)
        delta = activations[-1] - y

        # Store gradients
        nabla_w, nabla_b = [], []

        # Gradients for output layer
        # delta = (layer_size[-1], 1), activations[-2] = (layer_size[-2], 1)
        nabla_w.append(
            np.dot(delta, activations[-2].transpose())
        )  # (layer_size[-1], layer_size[-2])
        nabla_b.append(delta)  # (layer_size[-1], 1)

        # Backprop through hidden layers
        for l in range(len(self.weights) - 1, 0, -1):  # l from L-2 to 0
            # DIM: delta = (layer_size[l+1], 1), weights[l] = (layer_size[l+1], layer_size[l]), tanh_prime = (layer_size[l+1], 1)
            delta = np.dot(self.weights[l].transpose(), delta) * self.tanh_prime(
                zs[l - 1]
            )  # (layer_size[l], 1)

            # Insert at 0 (start) as opposed to append (last) since iterating backwards
            # delta = (layer_size[l], 1), activations[l-1] = (layer_size[l-1], 1)
            nabla_w.insert(
                0, np.dot(delta, activations[l - 1].transpose())
            )  # (layer_size[l], layer_size[l-1])
            nabla_b.insert(0, delta)  # (layer_size[l], 1)

        return nabla_w, nabla_b
